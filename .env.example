# ============================================================================
# Nudge environment variables
#
# このファイルを `.env` にコピーして、CHANGE_ME を実際の値に置き換えてください。
# 本番環境では .env をリポジトリに含めず、シークレットマネージャ経由で
# 注入することを推奨します。
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------

# マイグレーション・管理用の接続 URL（PostgreSQL superuser または DDL 権限を持つロール）
# 本番では絶対にアプリケーション実行時に使わないこと（RLS が素通しされる）
DATABASE_URL_ADMIN=postgresql://postgres:postgres@localhost:5432/nudge_dev

# アプリケーション実行時の接続 URL（nudge_app ロール、RLS 強制）
# パスワードは初回マイグレーション後に以下のコマンドで設定してください:
#   psql $DATABASE_URL_ADMIN -c "ALTER ROLE nudge_app PASSWORD '<secret>'"
DATABASE_URL_APP=postgresql://nudge_app:CHANGE_ME@localhost:5432/nudge_dev

# ----------------------------------------------------------------------------
# セッション暗号化
# ----------------------------------------------------------------------------

# iron-session の暗号化キー（32 文字以上のランダム値）
# このキーは以下にも使われます:
#   - 通知設定 DB 内の SMTP パスワード / Teams Webhook URL / Slack Webhook URL の AES-256-GCM 暗号化
# このキーを変更すると全ユーザーがログアウトされ、暗号化済みフィールドも復号不能になります
# 生成: openssl rand -base64 32
IRON_SESSION_PASSWORD=CHANGE_ME_TO_AT_LEAST_32_CHARS_RANDOM_STRING

# ----------------------------------------------------------------------------
# Keycloak (OIDC)
# ----------------------------------------------------------------------------

# テナントごとの Keycloak realm に作成した OIDC クライアントの credentials
# Confidential client であること、Service Accounts は同期用 API 認証で使用
OIDC_CLIENT_ID=nudge-web
OIDC_CLIENT_SECRET=CHANGE_ME

# OAuth2 redirect_uri のベース URL
# 最終的な redirect_uri は ${OIDC_REDIRECT_URI_BASE}/t/<tenant_code>/auth/callback になります
# 本番では https:// で始まる公開 URL を指定
OIDC_REDIRECT_URI_BASE=http://localhost:3000

# ----------------------------------------------------------------------------
# 同期 API
# ----------------------------------------------------------------------------

# cron 等から同期エンドポイント (POST /api/sync/keycloak) を叩く際の API キー
# 32 文字以上のランダム値を推奨。省略するとセッション認証のみで同期可能
SYNC_API_KEY=CHANGE_ME_TO_RANDOM_STRING

# ----------------------------------------------------------------------------
# その他
# ----------------------------------------------------------------------------

# Node.js 環境（cookie の Secure 属性などの判定に使用）
# 本番では production を指定
# NODE_ENV=production

# Keycloak の admin API 接続情報（admin URL / username / password）はテナントごとに
# DB の tenant テーブルおよび platform_admin から設定するため、env vars には含めません
